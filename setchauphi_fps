local function colorToTable(color)
    return {r = color.R, g = color.G, b = color.B}
end

local function tableToColor(t)
    if not t then return Color3.fromRGB(255, 255, 255) end
    return Color3.new(t.r, t.g, t.b)
end

local function SaveSettings()
    local data = {
        Aim = {
            Enabled = AimSettings.Enabled,
            Speed = AimSettings.Speed,
            ShowFov = AimSettings.ShowFov,
            FovSize = AimSettings.FovSize,
            WallCheck = AimSettings.WallCheck,
            MaxDistance = AimSettings.MaxDistance,
            FovColor = colorToTable(AimSettings.FovColor)
        },
        Player = PlayerSettings,
        Esp = {
            BoxEsp = EspSettings.BoxEsp,
            TracerEsp = EspSettings.TracerEsp,
            HighlightEsp = EspSettings.HighlightEsp,
            NameEsp = EspSettings.NameEsp,
            DistanceEsp = EspSettings.DistanceEsp,
            HealthEsp = EspSettings.HealthEsp,
            EspColor = colorToTable(EspSettings.EspColor)
        }
    }
    
    local success, jsonStr = pcall(function() return HttpService:JSONEncode(data) end)
    if success then
        writefile(FileName, jsonStr)
    end
end

local function LoadSettings()
    if isfile(FileName) then
        local rawData = readfile(FileName)
        local success, data = pcall(function() return HttpService:JSONDecode(rawData) end)
        
        if success and data then
            if data.Aim then
                AimSettings.Enabled = data.Aim.Enabled or false
                AimSettings.Speed = data.Aim.Speed or 0.2
                AimSettings.ShowFov = data.Aim.ShowFov or false
                AimSettings.FovSize = data.Aim.FovSize or 100
                AimSettings.WallCheck = data.Aim.WallCheck or false
                AimSettings.MaxDistance = data.Aim.MaxDistance or (100 * 3.57)
                if data.Aim.FovColor then AimSettings.FovColor = tableToColor(data.Aim.FovColor) end
            end
            
            if data.Player then
                for k, v in pairs(data.Player) do
                    PlayerSettings[k] = v
                end
                Camera.FieldOfView = PlayerSettings.PovValue
            end
            
            if data.Esp then
                EspSettings.BoxEsp = data.Esp.BoxEsp or false
                EspSettings.TracerEsp = data.Esp.TracerEsp or false
                EspSettings.HighlightEsp = data.Esp.HighlightEsp or false
                EspSettings.NameEsp = data.Esp.NameEsp or false
                EspSettings.DistanceEsp = data.Esp.DistanceEsp or false
                EspSettings.HealthEsp = data.Esp.HealthEsp or false
                if data.Esp.EspColor then EspSettings.EspColor = tableToColor(data.Esp.EspColor) end
            end
        end
    end
end

