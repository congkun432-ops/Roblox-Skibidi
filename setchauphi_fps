local function GetClosestPlayer()
	local ClosestTarget = nil
	local ShortestDistance = AimSettings.FovSize 
	local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

	for _, player in pairs(Players:GetPlayers()) do
		if player ~= localPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") then
			local Humanoid = player.Character.Humanoid
			local RootPart = player.Character.HumanoidRootPart
			
			if Humanoid.Health > 0 then
				local ScreenPosition, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)
				
				if OnScreen then
					local DistanceFromCenter = (Vector2.new(ScreenPosition.X, ScreenPosition.Y) - ScreenCenter).Magnitude
					
					if DistanceFromCenter < ShortestDistance then
						local ActualDistance = (localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")) and (RootPart.Position - localPlayer.Character.HumanoidRootPart.Position).Magnitude or 9999
						
						if ActualDistance <= AimSettings.MaxDistance then
							if AimSettings.WallCheck then
								local RaycastParam = RaycastParams.new()
								RaycastParam.FilterType = Enum.RaycastFilterType.Exclude
								RaycastParam.FilterDescendantsInstances = {localPlayer.Character, Camera}
								RaycastParam.IgnoreWater = true

								local RayOrigin = Camera.CFrame.Position
								local RayDirection = (RootPart.Position - RayOrigin).Unit * ActualDistance
								local RaycastResult = workspace:Raycast(RayOrigin, RayDirection, RaycastParam)

								if not RaycastResult or RaycastResult.Instance:IsDescendantOf(player.Character) then
									ShortestDistance = DistanceFromCenter
									ClosestTarget = RootPart
								end
							else
								ShortestDistance = DistanceFromCenter
								ClosestTarget = RootPart
							end
						end
					end
				end
			end
		end
	end
	return ClosestTarget
end

local function CreateEspObjects(player)
	if EspCache[player] then return end

	local Box = Drawing.new("Square")
	Box.Visible = false; Box.Color = EspSettings.EspColor; Box.Thickness = 1.5; Box.Filled = false

	local Tracer = Drawing.new("Line")
	Tracer.Visible = false; Tracer.Color = EspSettings.EspColor; Tracer.Thickness = 1.5

	local NameTag = Drawing.new("Text")
	NameTag.Visible = false; NameTag.Center = true; NameTag.Size = 13; NameTag.Outline = true; NameTag.Color = Color3.new(1, 1, 1)

	local HealthBar = Drawing.new("Square")
	HealthBar.Visible = false; HealthBar.Filled = true; HealthBar.Thickness = 0

	EspCache[player] = {Box = Box, Tracer = Tracer, NameTag = NameTag, HealthBar = HealthBar}
end

local function RemoveEspObjects(player)
    if EspCache[player] then
        if EspCache[player].Box then EspCache[player].Box:Remove() end
        if EspCache[player].Tracer then EspCache[player].Tracer:Remove() end
        if EspCache[player].NameTag then EspCache[player].NameTag:Remove() end
        if EspCache[player].HealthBar then EspCache[player].HealthBar:Remove() end
        
        if player.Character and player.Character:FindFirstChild("EspHighlight") then
            player.Character.EspHighlight:Destroy()
        end
        EspCache[player] = nil
    end
end

for _, player in pairs(Players:GetPlayers()) do
    CreateEspObjects(player)
    player.CharacterAdded:Connect(function()
        local char = player.Character
        if char and char:FindFirstChild("EspHighlight") then
            char.EspHighlight:Destroy()
        end
    end)
end

