local JumpCount = 0
local IsWindowOpen = false 
local HasClosedWindow = false 
local IsJumpingConnection = nil

local function SetupDoubleJump(character)
	local Humanoid = character:WaitForChild("Humanoid")
	local RootPart = character:WaitForChild("HumanoidRootPart")
	
	Humanoid.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Landed then
			JumpCount = 0
			IsWindowOpen = false
			HasClosedWindow = false
		end
	end)
	
	if IsJumpingConnection then IsJumpingConnection:Disconnect() end
	
	IsJumpingConnection = Humanoid:GetPropertyChangedSignal("Jump"):Connect(function()
		if Humanoid.Jump and PlayerSettings.DoubleJump and Humanoid.Health > 0 then
			JumpCount = JumpCount + 1
			
			if JumpCount == 1 and not IsWindowOpen and not HasClosedWindow then
				IsWindowOpen = true
				task.delay(0.5, function()
					IsWindowOpen = false
					HasClosedWindow = true 
				end)
			elseif IsWindowOpen and not HasClosedWindow then
				Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				local JumpForce = Humanoid.UseJumpHeight and (Humanoid.JumpHeight * 2.5) or Humanoid.JumpPower
				if JumpForce == 0 then JumpForce = 50 end
				RootPart.AssemblyLinearVelocity = Vector3.new(RootPart.AssemblyLinearVelocity.X, JumpForce, RootPart.AssemblyLinearVelocity.Z)
			end
		end
	end)
end

if localPlayer.Character then SetupDoubleJump(localPlayer.Character) end
localPlayer.CharacterAdded:Connect(SetupDoubleJump)
end)
